{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "exactOptionalPropertyTypes": false,
    "baseUrl": ".",
    "paths": {
      "@shaj/types": ["packages/types/src/index.ts"],
      "@shaj/utils": ["packages/utils/src/index.ts"],
      "@shaj/config": ["packages/config/src/index.ts"],
      "@shaj/database": ["packages/database/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "**/dist", "**/.next"]
}
