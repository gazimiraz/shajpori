{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shaj/types": ["../../packages/types/src/index.ts"],
      "@shaj/types/*": ["../../packages/types/src/*"],
      "@shaj/utils": ["../../packages/utils/src/index.ts"],
      "@shaj/utils/*": ["../../packages/utils/src/*"],
      "@shaj/database": ["../../packages/database/src/index.ts"],
      "@shaj/database/*": ["../../packages/database/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
