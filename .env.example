# ============================================
# SHAJ ECOM - Environment Configuration
# ============================================

# App
NODE_ENV=development
APP_NAME="Shaj Ecom"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_URL=http://localhost:3001
POS_URL=http://localhost:3002

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shaj_ecom
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/shaj_ecom_test

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Storage (AWS S3 / Cloudflare R2)
STORAGE_PROVIDER=local
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=shaj-ecom-assets
CDN_URL=

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=

# Shipping
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
REDX_API_KEY=
STEADFAST_API_KEY=
STEADFAST_API_SECRET=
PAPERFLY_API_KEY=
DHL_API_KEY=
FEDEX_API_KEY=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@shaj.com

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp
WHATSAPP_BUSINESS_ID=
WHATSAPP_ACCESS_TOKEN=

# Push Notifications
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# AI / OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=
ANTHROPIC_API_KEY=

# Analytics
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=

# Two-Factor Auth
TOTP_SECRET=your-totp-secret

# Barcode / Labels
LABEL_PRINTER_TYPE=thermal

# BullMQ / Queue
QUEUE_REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Multi-tenant / SaaS
TENANT_MODE=single
MASTER_TENANT_ID=

# Encryption
ENCRYPTION_KEY=32-character-encryption-key-here!
